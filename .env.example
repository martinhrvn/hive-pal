# Hive Pal Environment Configuration
# Copy this file to .env and fill in your values before starting the stack.

# ====================
# Required
# ====================

# Your public hostname (must match your DNS A record exactly)
DOMAIN=hivepal.yourdomain.com

# PostgreSQL password — use a strong random value in production
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@postgres:5432/beekeeper

# Built-in admin account
ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD must be a bcrypt hash — plain text will not work.
# Generate one with:
#   node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 12).then(h => console.log(h));"
# or:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt(12)).decode())"
ADMIN_PASSWORD=$2a$12$5m1UQcYmWiDRHrXrFFxoqeX4BTGOKQDINfhXX5j9CkUwdJ8F62hIq

# Public URL shown in emails and used for CORS
FRONTEND_URL=https://${DOMAIN}

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-long-random-string

# Public API URL used by the browser (leave as / when frontend and backend
# are served from the same origin, e.g. the single-container setup)
VITE_API_URL=https://api.yourdomain.com  # Public API URL (used by browser)

# Internal API URL used by the frontend container to reach the backend
# (only relevant when running frontend and backend as separate containers)
# API_URL=http://backend:3000

# Comma-separated list of origins allowed for CORS and Swagger
ALLOWED_ORIGINS=https://${DOMAIN},http://localhost:8080,http://localhost:5173

# Port the backend listens on (default: 3000)
# PORT=3000

# ====================
# Traefik / TLS (required when using docker-compose.traefik.yaml)
# ====================

# Email address Let's Encrypt uses for expiry notifications
ACME_EMAIL=admin@yourdomain.com

# ====================
# Storage
# ====================

# 'local' stores uploads on disk; 's3' uses any S3-compatible service (default: s3)
STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=/data/uploads

# S3-compatible storage (MinIO, Backblaze B2, AWS S3, etc.)
# S3_ENDPOINT=https://s3.yourdomain.com
# S3_REGION=us-east-1
# S3_BUCKET=hivepal-uploads
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# Maximum size for audio file uploads in bytes (default: 52428800 = 50 MB)
# AUDIO_MAX_FILE_SIZE=52428800

# ====================
# Email (optional — required for password reset)
# ====================

# The app auto-detects the provider from the variables present.
# If both are configured, Resend takes priority.
# Set MAIL_PROVIDER=none to explicitly disable email.
# MAIL_PROVIDER=smtp   # force: resend | smtp | none

# --- Option 1: Resend ---
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# --- Option 2: SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=false                  # true for port 465 (SSL), false for 587 (STARTTLS)
# SMTP_REJECT_UNAUTHORIZED=true      # set false only for self-signed certs

# Sender address used by both providers
# FROM_EMAIL=noreply@yourdomain.com

# ====================
# AI module (optional — voice-to-inspection)
# ====================

# AI_ENABLED=true
# AI_SERVICE_URL=http://hivepal-ai:8008
# AI_SERVICE_API_KEY=change-me-long-random-string   # must match AI_API_KEY in the AI container
# AI_REQUEST_TIMEOUT_MS=300000

# ====================
# Logging (optional)
# ====================

# Winston log level: error | warn | info | debug (default: info)
# LOG_LEVEL=info

# URL of a Loki instance for centralised log shipping
# LOKI_HOST=http://loki:3100

# ====================
# Error tracking (optional)
# ====================

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
