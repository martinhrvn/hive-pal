# paleta configuration file
# Generated by 'plt init'. Edit freely or re-run 'plt init' to update.
locations:
    - name: root
      location: .
      type:
        - pnpm
        - compose
        - docker
    - name: ai-app
      location: apps/ai-app
      type:
        - python
        - compose
        - docker
    - name: backend
      location: apps/backend
      type:
        - npm
        - compose
    - name: e2e
      location: apps/e2e
      type: npm
    - name: frontend
      location: apps/frontend
      type: npm
    - name: docs
      location: docs
      type: npm
    - name: page-objects
      location: packages/page-objects
      type: npm
    - name: shared-schemas
      location: packages/shared-schemas
      type: npm
